OCTETSTRINGS DEFINITIONS AUTOMATIC TAGS ::= BEGIN

-- unconstrained
OCTETSTRING-NULL-NULL-FALSE ::= OCTET STRING

-- semi-constrained (lb only)
OCTETSTRING-0-NULL-FALSE    ::= OCTET STRING (SIZE (0..MAX))

OCTETSTRINGS DEFINITIONS AUTOMATIC TAGS ::= BEGIN

-- unconstrained
OCTETSTRING-NULL-NULL-FALSE ::= OCTET STRING

-- semi-constrained (lb only)
OCTETSTRING-0-NULL-FALSE    ::= OCTET STRING (SIZE (0..MAX))
OCTETSTRING-1-NULL-FALSE    ::= OCTET STRING (SIZE (1..MAX))
OCTETSTRING-10-NULL-FALSE   ::= OCTET STRING (SIZE (10..MAX))

-- fixed size (lb==ub), not extensible
OCTETSTRING-1-1-FALSE       ::= OCTET STRING (SIZE (1))
OCTETSTRING-4-4-FALSE       ::= OCTET STRING (SIZE (4))
OCTETSTRING-8-8-FALSE       ::= OCTET STRING (SIZE (8))
OCTETSTRING-16-16-FALSE     ::= OCTET STRING (SIZE (16))
OCTETSTRING-64-64-FALSE     ::= OCTET STRING (SIZE (64))

-- boundary ranges (length determinant thresholds), not extensible
OCTETSTRING-1-127-FALSE     ::= OCTET STRING (SIZE (1..127))
OCTETSTRING-1-128-FALSE     ::= OCTET STRING (SIZE (1..128))
OCTETSTRING-1-255-FALSE     ::= OCTET STRING (SIZE (1..255))
OCTETSTRING-1-256-FALSE     ::= OCTET STRING (SIZE (1..256))

-- constrained (lb=0, various ub), not extensible

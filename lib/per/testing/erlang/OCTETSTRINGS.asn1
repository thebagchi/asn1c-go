OCTETSTRING-0-2097152-FALSE ::= OCTET STRING (SIZE (0..2097152))

-- constrained (lb=0, various ub), extensible
OCTETSTRING-0-0-TRUE        ::= OCTET STRING (SIZE (0, ...))
OCTETSTRING-0-1-TRUE        ::= OCTET STRING (SIZE (0..1, ...))
OCTETSTRING-0-2-TRUE        ::= OCTET STRING (SIZE (0..2, ...))
